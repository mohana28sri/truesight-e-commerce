# Example Environment Variables Configuration
# Copy this file to .env and replace the values with your actual secrets.

# 1. Server Configuration
# The port your Express backend should listen on (defaults to 3000 if not specified)
PORT=3000

# 2. Database paths (Optional)
# If deploying to Render with a persistent disk, set this to the mount path. 
# Defaults to server/database.sqlite locally
DB_PATH=/data/database.sqlite

# 3. Authentication Secrets
# Used to sign session tokens. Please use a strong, random, and secret key in production!
JWT_SECRET=your_super_secret_jwt_key_here
